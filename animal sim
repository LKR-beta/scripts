local lst={}
local lst2={}

local function pred(c)
local r=c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("LowerTorso")
if not r then return end
local p=r.Position
if not lst[c] then
lst[c]=p
lst2[c]=Vector3.zero
end
local v=p-lst[c]
lst[c]=p
local sm=v:Lerp(lst2[c],0.28)
lst2[c]=sm
local a=(sm-v)*1.45
local hh=Vector3.new(0,sm.Y*1.9,0)
local fr=r.CFrame.LookVector*3.6
return p+sm*1.45+a+hh+fr
end

local function near()
local ch=LP.Character
if not ch then return end
local r=ch:FindFirstChild("HumanoidRootPart")
if not r then return end
local t=nil
local ds=20
for _,pl in ipairs(P:GetPlayers()) do
if pl~=LP and pl.Character then
local h=pl.Character:FindFirstChild("Humanoid")
local rt=pl.Character:FindFirstChild("LowerTorso") or pl.Character:FindFirstChild("HumanoidRootPart")
if h and rt and h.Health>0 then
local d=(r.Position-rt.Position).Magnitude
if d<=ds then
t=h
ds=d
end
end
end
end
return t
end

local function high()
local ch=LP.Character
if not ch then return end
local r=ch:FindFirstChild("HumanoidRootPart")
if not r then return end
local t=nil
local hp=0
for _,pl in ipairs(P:GetPlayers()) do
if pl~=LP and pl.Character then
local h=pl.Character:FindFirstChild("Humanoid")
local rt=pl.Character:FindFirstChild("LowerTorso") or pl.Character:FindFirstChild("HumanoidRootPart")
if h and rt and h.Health>0 then
if (r.Position-rt.Position).Magnitude<=10 and h.Health>hp then
t=pl.Character
hp=h.Health
end
end
end
end
return t
end

